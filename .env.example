# ============================================
# HermesDigitalStudio 环境变量配置示例
# 复制此文件为 .env 并填入实际值
# ============================================

# --- Neo4j 数据库 ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bobo1234

# --- Hermes Agent 配置 ---
# Hermes 主目录（包含 config.yaml 和 .env）
HERMES_HOME=~/.hermes
# Studio 数据目录
HERMES_STUDIO_DATA_DIR=./data/studio
# 禁用嵌入式消息网关（Docker 环境设为 1）
HERMES_STUDIO_NO_EMBEDDED_GATEWAY=1

# --- AI 模型配置 ---
# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Ollama (本地模型)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- 向量数据库 ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your-qdrant-api-key

# --- 日志配置 ---
LOG_LEVEL=INFO
LOG_FILE=./logs/studio.log

# --- 端口配置 ---
BACKEND_PORT=9120
FRONTEND_PORT=5173
