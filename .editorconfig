# EditorConfig is awesome: https://EditorConfig.org

# 所有文件
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Python 文件
[*.py]
indent_size = 4
max_line_length = 100

# TypeScript / JavaScript
[*.{ts,tsx,js,jsx}]
indent_size = 2

# JSON / YAML / TOML
[*.{json,yaml,yml,toml}]
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false

# Dockerfile
[Dockerfile*]
indent_size = 2

# Makefile
[Makefile]
indent_style = tab
